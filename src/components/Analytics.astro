---
import { analytics } from '../config/site';
// Env var wins (per-deploy override); otherwise fall back to the site's
// committed Measurement ID. GA4 IDs are public, so this is safe to commit.
const id = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID || analytics.ga4MeasurementId;
---

{
  id ? (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${id}`} />
      <script is:inline define:vars={{ measurementId: id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag('js', new Date());
        gtag('config', measurementId);
      </script>
    </>
  ) : null
}
