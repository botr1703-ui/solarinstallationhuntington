---
/**
 * Icon — stroke-based line icon set, 24x24, currentColor.
 * Replaces text/emoji icons across the site (emoji literals in JSX
 * ternaries break the Astro 16 Cloudflare edge runtime — see vault note).
 *
 * Usage: <Icon name="house" />  with size + class overrides optional.
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: klass = '' } = Astro.props;

// Each entry is the inner markup of a 24x24 stroke icon (trusted, authored here).
const icons: Record<string, string> = {
  sun: '<circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.5M12 19v2.5M2.5 12h2.5M19 12h2.5M5 5l1.8 1.8M17.2 17.2 19 19M19 5l-1.8 1.8M6.8 17.2 5 19"/>',
  house: '<path d="M3.5 11.5 12 4l8.5 7.5"/><path d="M5.5 10v9.5h13V10"/><path d="M10 19.5v-5h4v5"/>',
  building: '<rect x="5" y="3.5" width="14" height="17"/><path d="M9 7.5h2M13 7.5h2M9 11h2M13 11h2M9 14.5h2M13 14.5h2"/><path d="M10 20.5v-3h4v3"/>',
  battery: '<rect x="3" y="7.5" width="15" height="9" rx="2"/><path d="M21 10.5v3"/><path d="M7 10.5v3M10.5 10.5v3"/>',
  wrench: '<path d="M15.5 5.5a4.5 4.5 0 0 0-5.9 5.7L4 16.8a2 2 0 1 0 3.2 3.2l5.6-5.6a4.5 4.5 0 0 0 5.7-5.9l-2.6 2.6-2.7-.7-.7-2.7 2.6-2.6Z"/>',
  document: '<path d="M6 3.5h8l4 4v13H6z"/><path d="M14 3.5v4h4"/><path d="M9 12h6M9 15.5h6M9 8.5h2"/>',
  dollar: '<circle cx="12" cy="12" r="8.5"/><path d="M14.5 9.2a2.6 2.6 0 0 0-2.5-1.4c-1.5 0-2.6.8-2.6 2 0 2.8 5.4 1.5 5.4 4.4 0 1.3-1.2 2.1-2.8 2.1a2.9 2.9 0 0 1-2.8-1.6M12 6.5v11"/>',
  percent: '<circle cx="12" cy="12" r="8.5"/><path d="M8.5 8.5h.01M15.5 15.5h.01M15.5 8.5 8.5 15.5"/>',
  clock: '<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/>',
  zap: '<path d="M13 2.5 4.5 13.5H11l-1 8 8.5-11H12z"/>',
  shield: '<path d="M12 3 5 5.5v5c0 4.5 3 8 7 9.5 4-1.5 7-5 7-9.5v-5z"/>',
  shieldCheck: '<path d="M12 3 5 5.5v5c0 4.5 3 8 7 9.5 4-1.5 7-5 7-9.5v-5z"/><path d="M9 11.5 11.2 14 15 9.5"/>',
  award: '<circle cx="12" cy="9" r="5.5"/><path d="M8.5 13.5 7 21l5-2.5L17 21l-1.5-7.5"/>',
  star: '<path d="M12 3.5 14.6 9l6 .7-4.5 4 1.3 5.9L12 16.6 6.6 19.6 7.9 13.7l-4.5-4 6-.7z"/>',
  users: '<circle cx="9" cy="8" r="3.2"/><path d="M3.5 20c0-3.3 2.5-5.5 5.5-5.5s5.5 2.2 5.5 5.5"/><path d="M16 5.2a3.2 3.2 0 0 1 0 6.1M17.5 14.8c2 .8 3.5 2.7 3.5 5.2"/>',
  search: '<circle cx="10.5" cy="10.5" r="6.5"/><path d="m20 20-4.7-4.7"/>',
  panel: '<rect x="3.5" y="4" width="17" height="11" rx="1"/><path d="M3.5 8h17M3.5 11.5h17M9 4v11M15 4v11M12 15v5M8.5 20h7"/>',
  check: '<path d="M5 12.5 10 17.5 19 7"/>',
  arrowRight: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  phone: '<path d="M6.5 4h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2.2 2A16 16 0 0 1 4.5 6.2 2 2 0 0 1 6.5 4Z"/>',
  leaf: '<path d="M4 20s.5-7 5-11.5S20 4 20 4s.5 7-4 11.5S4 20 4 20Z"/><path d="M4 20 14 10"/>',
  bolt: '<path d="M13 2.5 4.5 13.5H11l-1 8 8.5-11H12z"/>',
};

const inner = icons[name] || icons.sun;
---

<svg
  class={'icon ' + klass}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  role="img"
  aria-hidden="true"
  set:html={inner}
/>
