---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
import Logo from '../components/Logo.astro';
import Icon from '../components/Icon.astro';
import { areas, services } from '../config/site';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const { title, description, canonicalPath, jsonLd, noindex } = Astro.props;

const business = import.meta.env.PUBLIC_BUSINESS_NAME || 'Huntington Solar Co';
const phoneDisplay = import.meta.env.PUBLIC_PHONE_DISPLAY || '(631) 759-8716';
const phoneTel = import.meta.env.PUBLIC_PHONE_TEL || '+16317598716';
const city = import.meta.env.PUBLIC_CITY || 'Huntington';
const year = new Date().getFullYear();
const firstService = services[0];
const firstArea = areas[0];
---

<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd} jsonLdExtra={jsonLdExtra} noindex={noindex} />
    <Analytics />
  </head>
  <body>
    <header>
      <div class="wrap">
        <a class="brand" href="/" aria-label={business + ' — home'}><Logo size={38} /></a>

        <input type="checkbox" id="navToggle" class="nav-toggle" hidden />
        <label for="navToggle" class="nav-burger" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </label>

        <nav class="nav" aria-label="Primary">
          <div class="nav-item nav-has-menu">
            <a href={firstService ? '/services/' + firstService.slug + '/' : '/#services'} class="nav-trigger">Services <span class="nav-caret" aria-hidden="true">▾</span></a>
            <div class="nav-menu" role="menu">
              {services.map(function (s) {
                return <a class="nav-menu-link" href={'/services/' + s.slug + '/'} role="menuitem">{s.title}</a>;
              })}
            </div>
          </div>
          <div class="nav-item nav-has-menu">
            <a href={firstArea ? '/locations/' + firstArea.slug + '/' : '/#areas'} class="nav-trigger">Areas <span class="nav-caret" aria-hidden="true">▾</span></a>
            <div class="nav-menu" role="menu">
              {areas.map(function (a) {
                return <a class="nav-menu-link" href={'/locations/' + a.slug + '/'} role="menuitem">Solar in {a.title}</a>;
              })}
            </div>
          </div>
          <div class="nav-item nav-has-menu">
            <a href="/incentives/" class="nav-trigger">Resources <span class="nav-caret" aria-hidden="true">▾</span></a>
            <div class="nav-menu" role="menu">
              <a class="nav-menu-link" href="/incentives/" role="menuitem">Incentives</a>
              <a class="nav-menu-link" href="/financing/" role="menuitem">Financing</a>
              <a class="nav-menu-link" href="/process/" role="menuitem">Our process</a>
              <a class="nav-menu-link" href="/warranty/" role="menuitem">Warranty</a>
              <a class="nav-menu-link" href="/case-studies/" role="menuitem">Case studies</a>
              <a class="nav-menu-link" href="/insights/" role="menuitem">Insights</a>
            </div>
          </div>
          <a href="/about/">About</a>
          <a class="nav-quote" href="/#contact">Get a quote</a>
          <a class="phone-cta" href={'tel:' + phoneTel}><Icon name="phone" size={16} /> {phoneDisplay}</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="wrap foot-grid">
        <div class="foot-col">
          <div class="foot-brand"><Logo size={40} variant="light" /></div>
          <p>Residential and commercial solar across {city} and the Suffolk County north shore. NABCEP-certified · NYSERDA-approved · Licensed and insured.</p>
          <p class="foot-phone"><a href={'tel:' + phoneTel}>{phoneDisplay}</a></p>
        </div>
        <div class="foot-col">
          <h4>Services</h4>
          <ul>
            {services.map(function (s) {
              return <li><a href={'/services/' + s.slug + '/'}>{s.title}</a></li>;
            })}
          </ul>
        </div>
        <div class="foot-col">
          <h4>Areas served</h4>
          <ul>
            {areas.map(function (a) {
              return <li><a href={'/locations/' + a.slug + '/'}>{a.title}</a></li>;
            })}
          </ul>
        </div>
        <div class="foot-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about/">About</a></li>
            <li><a href="/financing/">Financing</a></li>
            <li><a href="/incentives/">Incentives</a></li>
            <li><a href="/warranty/">Warranty</a></li>
            <li><a href="/process/">Our process</a></li>
            <li><a href="/case-studies/">Case studies</a></li>
            <li><a href="/insights/">Insights</a></li>
            <li><a href="/#contact">Get a quote</a></li>
            <li><a href={'tel:' + phoneTel}>Call {phoneDisplay}</a></li>
          </ul>
        </div>
      </div>
      <div class="wrap foot-creds">
        <span class="foot-cred">NABCEP Certified</span>
        <span class="foot-cred">NYSERDA NY-Sun Installer</span>
        <span class="foot-cred">Tesla Powerwall Certified</span>
        <span class="foot-cred">Enphase Platinum Installer</span>
        <span class="foot-cred">BBB A+ Rated</span>
        <span class="foot-cred">★ 4.9 · 127 reviews</span>
      </div>
      <div class="wrap foot-legal">
        <span>© {year} {business}. Licensed and Insured · Suffolk County, NY</span>
        <span class="foot-legal-links">
          <a href="/privacy/">Privacy</a>
          <span aria-hidden="true">·</span>
          <a href="/terms/">Terms</a>
        </span>
      </div>
    </footer>

    <!-- GA4 phone-click conversion. No-ops if GA4 isn't configured. -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href^="tel:"]');
        if (a && typeof gtag === 'function') {
          gtag('event', 'phone_click', { event_category: 'lead', transport_type: 'beacon' });
        }
      });
    </script>
  </body>
</html>
